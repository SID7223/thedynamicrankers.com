{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dynamic-rankers",
  "pages_build_output_dir": "dist",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dr-command-center",
      "database_id": "REPLACE_WITH_ACTUAL_ID"
    }
  ],
  "vars": {
    "JWT_SECRET": "REPLACE_WITH_SECURE_SECRET"
  }
}
